# ============================================
# Smart Canteen - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交
# ============================================

# 服务端口
SERVER_PORT=8080

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_canteen
DB_USER=root
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here_change_this
